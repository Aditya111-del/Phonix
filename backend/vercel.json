{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "PORT": "5000",
    "NODE_ENV": "production",
    "JWT_SECRET": "@phonix-jwt-secret",
    "MONGODB_URI": "@mongodb-uri",
    "FRONTEND_URL": "https://phonix-two.vercel.app",
    "OPENROUTER_API_KEY": "@openrouter-key",
    "ALPHA_VANTAGE_KEY": "@alpha-vantage-key"
  }
}
